  _theme_download \
    "tokyonight-moon" \
    "https://github.com/user-attachments/files/26270035/Tokyonight-BL-LB-dark-Moon.zip" \
    "Tokyonight-BL-LB-Dark-Moon"

  _theme_download \
    "gruvbox-dark-medium" \
    "https://github.com/user-attachments/files/26270135/Gruvbox-BL-LB-dark-Medium.zip" \
    "Gruvbox-BL-LB-Dark-Medium"

  printf "\nThey were installed to '%s'\n" "${XDG_DATA_HOME}/themes/"
}

