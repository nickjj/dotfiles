#!/usr/bin/env bash
# Set the timezone.

set -o errexit
set -o pipefail
set -o nounset

tz="$(timedatectl list-timezones | walker --dmenu --placeholder "Set timezone...")"

if [ -n "${tz}" ]; then
  sudo timedatectl set-timezone "${tz}"
  dot-reload-app waybar
  notify-send "Timezone set to ${tz}"
fi
