#!/usr/bin/env bash
# Browse git log through fzf, it will search both commit messages and code.
# Anything you can pass to git log you can pass to this script. It also
# supports passing in --side to configure delta to use side-by-side mode.
#
# Examples:
#   gl
#   gl --side
#   gl [any flag that git log supports]

set -o errexit
set -o pipefail
set -o nounset

git_args=()

# Handle displaying side by side on demand.
for arg in "${@}"; do
  if [ "${arg}" = "--side" ]; then
    export DELTA_FEATURES="${DELTA_FEATURES} side-by-side"
  else
    git_args+=("${arg}")
  fi
done

git_args_str="--color=always --date=short ${git_args[*]}"

# %at is a hidden timestamp, it it used for sorting later.
# COLOR is a placeholder that changes depending on the search result type.
format="%at %C(magenta)%h %C(green)%ad %C(COLOR)> %C(reset)%s"
format_message="${format//COLOR/blue}"
format_code="${format//COLOR/yellow}"

strip_timestamp="cut --delimiter ' ' --fields 2-"

git_log_default="git log --pretty='${format_message}' ${git_args_str} | ${strip_timestamp}"

# There's a lot going on here, here's a few comments for my future self:
#
# start:reload
#   Run this when fzf starts, this works instead of piping in git log because
#   we also use --disabled.
#
# change:reload:sleep
#   change  fires every time a key is pressed
#   reload  starts a new process with the typed query
#   sleep   acts as a 150ms debounce to trigger the change / reload
#
# [[ \"\$query\" =~ [A-Z] ]] && flag=\"\" || flag=\"--regexp-ignore-case\"
#   This is effectively smart casing, if any capital letters exist then the
#   search is case sensitive, otherwise it's case insensitive.
#
# --grep and -G run as separate searches to make them an OR instead of AND,
# we run them in a subshell to sort their results later. We always want newest
# commits on top, sorted by the hidden timestamp and we use a different > color
# to know if it's a message (blue) or code (yellow) result.
fzf --ansi --disabled --no-sort --query "" \
  --bind "start:reload(${git_log_default})" \
  --bind "change:reload:sleep 0.15;
        query={q};
        if [ -z \"\$query\" ]; then
          ${git_log_default};
        else
          [[ \"\$query\" =~ [A-Z] ]] && flag=\"\" || flag=\"--regexp-ignore-case\";
          (git log \${flag} --pretty='${format_code}' ${git_args_str} -G\"\$query\";
           git log \${flag} --pretty='${format_message}' ${git_args_str} --grep=\"\$query\") |
           sort --numeric-sort --reverse --unique --key=1,1 |
           ${strip_timestamp};
        fi" \
  --bind "enter:execute(git show {1} -- | delta --paging always)" \
  --preview "git show {1} -- | delta --width=\${FZF_PREVIEW_COLUMNS}" \
  --preview-window="right:70%" || true
